---
layout: null
permalink: /search.json
---
[
  {% for post in site.posts %}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | absolute_url | jsonify }},
    "date": {{ post.date | date: "%d %b %Y" | jsonify }},
    "sort_date": {{ post.date | date_to_xmlschema | jsonify }},
    "tags": {{ post.tags | join: " " | jsonify }},
    "description": {{ post.description | default: post.excerpt | strip_html | strip_newlines | jsonify }},
    "content": {{ post.content | markdownify | strip_html | strip_newlines | jsonify }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
